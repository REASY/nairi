}

uretprobe:/apex/com.android.runtime/lib64/bionic/libc.so:stat /((uint64)uid) == @target_uid/
{
    $n = @stat_seq[tid];
    if ($n != 0) {
        $rc = (int64)retval;
        $ok = $rc == 0 ? 1 : 0;
        $err = $ok == 1 ? 0 : @fs_errno[tid];
        printf("[obs-fs][%d] stat uid=%d pid=%d tid=%d comm=%s path=%s rc=%ld ok=%d errno=%d\n",
               $n, uid, pid, tid, comm, str(@stat_path[tid], 112), $rc, $ok, $err);
        if (@stack == 1) {
            if (@stack_depth == 10) {
                print(ustack(10));
            } else if (@stack_depth == 20) {
                print(ustack(20));
            } else if (@stack_depth == 80) {
                print(ustack(80));
            } else if (@stack_depth == 120) {
                print(ustack(120));
            } else {
                print(ustack(40));
            }
        }
        delete(@stat_seq[tid]);
        delete(@stat_path[tid]);
        delete(@fs_inflight[tid]);
        delete(@fs_errno[tid]);
    }
}

