uretprobe:/apex/com.android.runtime/lib64/bionic/libc.so:readlinkat /((uint64)uid) == @target_uid/
{
    $n = @readlinkat_seq[tid];
    if ($n != 0) {
        $rc = (int64)retval;
        $ok = $rc >= 0 ? 1 : 0;
        $err = $ok == 1 ? 0 : @fs_errno[tid];
        printf("[obs-fs][%d] readlinkat uid=%d pid=%d tid=%d comm=%s path=%s rc=%ld ok=%d errno=%d\n",
               $n, uid, pid, tid, comm, str(@readlinkat_path[tid], 112), $rc, $ok, $err);
