        $rc = (int64)retval;
        $ok = $rc == 0 ? 1 : 0;
        $err = $ok == 1 ? 0 : @fs_errno[tid];
        printf("[obs-fs][%d] lstat uid=%d pid=%d tid=%d comm=%s path=%s rc=%ld ok=%d errno=%d\n",
               $n, uid, pid, tid, comm, str(@lstat_path[tid], 112), $rc, $ok, $err);
        if (@stack == 1) {
            if (@stack_depth == 10) {
                print(ustack(10));
            } else if (@stack_depth == 20) {
                print(ustack(20));
            } else if (@stack_depth == 80) {
                print(ustack(80));
            } else if (@stack_depth == 120) {
                print(ustack(120));
            } else {
                print(ustack(40));
            }
        }
        delete(@lstat_seq[tid]);
