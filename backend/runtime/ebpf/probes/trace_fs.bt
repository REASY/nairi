uprobe:/apex/com.android.runtime/lib64/bionic/libc.so:opendir /((uint64)uid) == @target_uid/
{
    $n = ++@fs_events;
    if (@sample == 0 || ($n <= 180 || (((uint64)$n % 20) == 0))) {
        @opendir_seq[tid] = $n;
        @opendir_path[tid] = arg0;
        @fs_inflight[tid] = 1;
        @fs_errno[tid] = 0;
    }
}

uretprobe:/apex/com.android.runtime/lib64/bionic/libc.so:opendir /((uint64)uid) == @target_uid/
{
    $n = @opendir_seq[tid];
    if ($n != 0) {
        $ret = (uint64)retval;
        $ok = $ret != 0 ? 1 : 0;
        $err = $ok == 1 ? 0 : @fs_errno[tid];
        printf("[obs-fs][%d] opendir uid=%d pid=%d tid=%d comm=%s path=%s ret=0x%lx ok=%d errno=%d\n",
               $n, uid, pid, tid, comm, str(@opendir_path[tid], 112), $ret, $ok, $err);
        if (@stack == 1) {
            if (@stack_depth == 10) {
                print(ustack(10));
            } else if (@stack_depth == 20) {
                print(ustack(20));
            } else if (@stack_depth == 80) {
                print(ustack(80));
            } else if (@stack_depth == 120) {
                print(ustack(120));
            } else {
                print(ustack(40));
            }
        }
        delete(@opendir_seq[tid]);
        delete(@opendir_path[tid]);
        delete(@fs_inflight[tid]);
        delete(@fs_errno[tid]);
    }
}

interval:s:3
{
    printf("[obs-fs] uid=%d fs_events=%d\n", @target_uid, @fs_events);
}

END
{
    clear(@openat_seq);
    clear(@openat_path);
    clear(@access_seq);
    clear(@access_path);
    clear(@stat_seq);
    clear(@stat_path);
    clear(@lstat_seq);
    clear(@lstat_path);
    clear(@readlink_seq);
    clear(@readlink_path);
    clear(@readlinkat_seq);
    clear(@readlinkat_path);
    clear(@opendir_seq);
    clear(@opendir_path);
    clear(@fs_inflight);
    clear(@fs_errno);
    printf("[obs-fs] done uid=%d fs_events=%d\n", @target_uid, @fs_events);
}
