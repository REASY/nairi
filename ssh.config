Host gcp-arm64
  User reasyu
  IdentityFile ~/.ssh/gcp-key
  ServerAliveInterval 30
  ServerAliveCountMax 3
  ExitOnForwardFailure yes

  # ADB (local -> remote)
  LocalForward 15555 localhost:5555

  # SOCKS5 Gateway (remote -> local)
  RemoteForward 0.0.0.0:10080 127.0.0.1:10080

  # SOCKS5 Admin API (remote -> local)
  RemoteForward 0.0.0.0:19000 127.0.0.1:19000
